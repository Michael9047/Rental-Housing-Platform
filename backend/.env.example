# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rental:rental@localhost:5432/rental_housing
ALEMBIC_DATABASE_URL=postgresql+psycopg://rental:rental@localhost:5432/rental_housing

# ── Redis / Celery ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ───────────────────────────────────────────────────
AUTH_SECRET_KEY=change-me-to-a-random-string
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# ── Amap (高德地图) ────────────────────────────────────────
AMAP_WEB_KEY=
AMAP_GEOCODE_URL=https://restapi.amap.com/v3/geocode/geo
AMAP_AROUND_URL=https://restapi.amap.com/v5/place/around

# ── Upload ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880

# ── WeChat Mini Program ────────────────────────────────────
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_TOKEN_URL=https://api.weixin.qq.com/cgi-bin/token

# ── WeChat Pay V3 ──────────────────────────────────────────
# Optional for local development. Leave empty to use the simulated callback flow.
WECHAT_PAY_MCHID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_REFUND_NOTIFY_URL=

# ── SMS (Alibaba Cloud) ────────────────────────────────────
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_ENDPOINT=dysmsapi.aliyuncs.com

# ── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Rental Housing
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
