# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rental:rental@localhost:5432/rental_housing
ALEMBIC_DATABASE_URL=postgresql+psycopg://rental:rental@localhost:5432/rental_housing

# ── Redis / Celery ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
PRIVATE_OBJECT_DIR=./private_objects

# ── Auth ───────────────────────────────────────────────────
AUTH_SECRET_KEY=change-me-to-a-random-string
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# DeepSeek LLM?AI ????????? + ?????
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 智谱 AI（Embedding，OpenAI 兼容接口，优先于 OpenAI）──────
ZHIPU_API_KEY=
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_DIMENSIONS=1536

# ── Amap (高德地图) ────────────────────────────────────────
AMAP_WEB_KEY=
AMAP_GEOCODE_URL=https://restapi.amap.com/v3/geocode/geo
AMAP_AROUND_URL=https://restapi.amap.com/v5/place/around

# ── OpenRouteService（OSM 全球路线引擎）─────────────────────
ORS_API_KEY=
ORS_DIRECTIONS_URL=https://api.openrouteservice.org/v2/directions
ORS_TIMEOUT_SECONDS=8.0

# ── Upload ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880

# ── WeChat Mini Program ────────────────────────────────────
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_TOKEN_URL=https://api.weixin.qq.com/cgi-bin/token

# ── SMS (Alibaba Cloud 号码认证 dypnsapi) ──────────────────
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_SCHEME_NAME=default
SMS_ENDPOINT=dypnsapi.aliyuncs.com

# ── Email (SMTP) — deprecated，DirectMail 稳定后移除 ──────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Rental Housing
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
EMAIL_DELIVERY_MODE=mailpit
SUPPORT_EMAIL=support@localhost
# Mailpit 本地预览（无认证、无真实投递）
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_EMAIL=no-reply@localhost
SMTP_USE_TLS=false

# ── Email (阿里云 DirectMail) — 主引擎，支持附件 ──────────
DM_ACCESS_KEY_ID=
DM_ACCESS_KEY_SECRET=
# 发件地址：需在阿里云 DirectMail 控制台提前验证
DM_ACCOUNT_NAME=
DM_FROM_ALIAS=Rental Housing
DM_REGION_ID=cn-hangzhou
DM_ENDPOINT=dm.aliyuncs.com
DM_TIMEOUT_SECONDS=10.0

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# 本地托管支付模拟器；不得在生产环境使用此密钥或 provider
PAYMENT_PROVIDER=mock_hosted
PAYMENT_MOCK_WEBHOOK_SECRET=local-test-only-change-me
PAYMENT_MOCK_MERCHANT_ACCOUNT=mock_test_account
PAYMENTS_LIVE_ENABLED=false

# 微信支付商户 API（仅填服务器安全配置，不提交私钥）
WECHAT_PAY_MERCHANT_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=

# 支付宝商户 API
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_PATH=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# 银行卡收单 Hosted Checkout / 官方 Payment Element
CARD_PROVIDER=
CARD_SECRET_KEY=
CARD_PUBLISHABLE_KEY=
CARD_WEBHOOK_SECRET=
CARD_SUCCESS_URL=
CARD_CANCEL_URL=
CONTRACT_EXPIRING_SOON_DAYS=30

# ── Celery ─────────────────────────────────────────────────
# 本地开发可设为 true 让 Celery 任务同步执行（不需要 Redis）
CELERY_TASK_ALWAYS_EAGER=
CELERY_TASK_EAGER_PROPAGATES=
