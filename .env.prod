# =============================================================================
# Production Environment Variables — Rental Housing Matching System
# =============================================================================
# Copy this file to .env.prod and fill in real values before deploying.
# NEVER commit .env.prod with real secrets to version control.
# =============================================================================

APP_NAME="Rental Housing Matching System"
ENVIRONMENT=production
DEBUG=false

# ---- Database ----
POSTGRES_DB=rental_housing
POSTGRES_USER=rental
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ---- Redis ----
REDIS_PASSWORD=change-me-to-a-strong-password

# ---- Auth (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))") ----
AUTH_SECRET_KEY=change-me-to-a-64-char-random-string
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- CORS (comma-separated allowed origins in production) ----
CORS_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-production-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# ---- File Uploads ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]
MAX_IMAGES_PER_PROPERTY=10

# ---- WeChat Mini Program ----
WECHAT_APPID=your-production-appid
WECHAT_SECRET=your-production-secret

# ---- WeChat Pay V3 ----
WECHAT_PAY_MCHID=your-merchant-id
WECHAT_PAY_API_V3_KEY=your-api-v3-key
WECHAT_PAY_SERIAL_NO=your-merchant-cert-serial-no
WECHAT_PAY_PRIVATE_KEY_PATH=/run/secrets/wechat_pay_private_key.pem
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/v1/payments/wechat/callback
WECHAT_PAY_REFUND_NOTIFY_URL=https://your-domain.com/api/v1/payments/wechat/refund-callback

# ---- Rate Limiting ----
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ---- Nginx ----
NGINX_PORT=80
