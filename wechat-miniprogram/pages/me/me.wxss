/* pages/me/me.wxss */
.page { padding-bottom: 40rpx; }

.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.login-hint { font-size: 28rpx; color: #999; margin-bottom: 40rpx; }

.wx-login-btn {
  width: 400rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 40rpx;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #07c160, #05a650);
  color: #fff;
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #fff;
  margin-right: 24rpx;
}

.user-detail { flex: 1; }
.user-name { font-size: 36rpx; font-weight: 600; margin-bottom: 8rpx; }
.user-role { font-size: 26rpx; opacity: 0.8; }
.user-phone { font-size: 24rpx; opacity: 0.7; margin-top: 4rpx; }

.menu-section {
  margin: 20rpx 30rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.menu-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.menu-label { font-size: 30rpx; color: #333; }
.menu-arrow { font-size: 28rpx; color: #ccc; }

.menu-value.bound { color: #07c160; font-size: 26rpx; }
.menu-value.unbound { color: #999; font-size: 26rpx; }

.phone-btn {
  margin-top: 16rpx;
  background: #07c160;
  color: #fff;
  font-size: 26rpx;
}

.role-switch { display: flex; }
.role-option {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  margin-left: 12rpx;
  color: #666;
}
.role-option.active { border-color: #07c160; color: #07c160; background: #e8f8ef; }

.logout-section { padding: 40rpx 30rpx; }
.logout-btn { background: #f5f5f5; color: #999; font-size: 28rpx; }
