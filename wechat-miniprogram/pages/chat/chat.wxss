/* pages/chat/chat.wxss */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.message-list {
  flex: 1;
  padding: 20rpx 30rpx;
  background: #f5f5f5;
}

.message-wrapper {
  margin-bottom: 24rpx;
  display: flex;
}

.message-wrapper.user {
  justify-content: flex-end;
}

.message-wrapper.assistant {
  justify-content: flex-start;
}

.message-bubble {
  max-width: 80%;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.message-wrapper.user .message-bubble {
  background: #07c160;
  color: #fff;
  border-bottom-right-radius: 4rpx;
}

.message-wrapper.assistant .message-bubble {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

.empty-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #ccc;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  background: #07c160;
  color: #fff;
  font-size: 26rpx;
  padding: 0 30rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
}

.send-btn[disabled] {
  background: #ccc;
}
