/* pages/search/search.wxss */
.page {
  padding-bottom: 20rpx;
}

.filters {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  padding: 8rpx 20rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.filter-price {
  width: 120rpx;
  padding: 8rpx 16rpx;
  font-size: 26rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.property-list {
  padding: 10rpx 30rpx;
}

.empty, .loading, .no-more {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}
