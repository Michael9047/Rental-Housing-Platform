/* pages/property/property.wxss */
.page {
  padding-bottom: 120rpx;
}

.image-swiper {
  height: 500rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

.info-section {
  padding: 30rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.price {
  font-size: 44rpx;
  font-weight: 700;
  color: #f56c6c;
}

.unit {
  font-size: 28rpx;
  color: #f56c6c;
  margin-right: 16rpx;
}

.property-type {
  font-size: 24rpx;
  color: #07c160;
  background: #e8f8ef;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.address {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

.section {
  padding: 30rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
}

.detail-item {
  width: 50%;
  display: flex;
  padding: 12rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
  width: 80rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 16rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.call-btn {
  flex: 1;
  margin-right: 20rpx;
  border: 1px solid #07c160;
  color: #07c160;
  background: #fff;
  font-size: 30rpx;
  border-radius: 8rpx;
}

.book-btn {
  flex: 1;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  border-radius: 8rpx;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-property {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-textarea {
  width: 100%;
  height: 150rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 26rpx;
  margin-bottom: 30rpx;
}

.modal-buttons {
  display: flex;
}

.cancel-btn {
  flex: 1;
  margin-right: 20rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
}

.confirm-btn {
  flex: 1;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
}
