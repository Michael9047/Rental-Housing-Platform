<!--pages/booking/booking.wxml-->
<view class="page">
  <view class="tabs">
    <view class="tab {{statusTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="onTabChange">全部</view>
    <view class="tab {{statusTab === 'pending' ? 'active' : ''}}" data-tab="pending" bindtap="onTabChange">待处理</view>
    <view class="tab {{statusTab === 'approved' ? 'active' : ''}}" data-tab="approved" bindtap="onTabChange">已确认</view>
    <view class="tab {{statusTab === 'cancelled' ? 'active' : ''}}" data-tab="cancelled" bindtap="onTabChange">已取消</view>
  </view>

  <view class="booking-list">
    <block wx:for="{{filteredBookings}}" wx:key="id">
      <view class="booking-card" bindtap="onTapBooking" data-id="{{item.id}}">
        <image class="booking-cover" src="{{item.property_cover}}" mode="aspectFill" wx:if="{{item.property_cover}}" />
        <view class="booking-info">
          <view class="booking-title">{{item.property_title || '房源'}}</view>
          <view class="booking-time">{{item.viewing_time || item.created_at}}</view>
          <view class="booking-status status-{{item.status}}">{{item.status === 'pending' ? '待处理' : item.status === 'approved' ? '已确认' : item.status === 'cancelled' ? '已取消' : item.status === 'rejected' ? '已拒绝' : item.status}}</view>
        </view>
      </view>
    </block>
  </view>

  <view class="empty" wx:if="{{!loading && filteredBookings.length === 0}}">
    <text>暂无预约记录</text>
  </view>
</view>
