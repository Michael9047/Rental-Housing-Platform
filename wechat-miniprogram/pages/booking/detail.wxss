/* pages/booking/detail.wxss */
.page { padding-bottom: 40rpx; }

.status-banner {
  text-align: center;
  padding: 40rpx 0;
  font-size: 36rpx;
  font-weight: 600;
}
.status-pending { color: #e6a23c; background: #fdf6ec; }
.status-approved { color: #07c160; background: #e8f8ef; }
.status-cancelled, .status-rejected { color: #999; background: #f5f5f5; }

.card {
  margin: 20rpx 30rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.label { font-size: 26rpx; color: #999; }
.value { font-size: 26rpx; color: #333; }

.action { padding: 30rpx; }
.cancel-btn { background: #f5f5f5; color: #999; font-size: 28rpx; }

.loading { text-align: center; padding: 200rpx 0; color: #999; }
