/* components/search-bar/search-bar.wxss */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.search-input {
  flex: 1;
  margin: 0 16rpx;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #07c160;
  padding: 8rpx 16rpx;
}
