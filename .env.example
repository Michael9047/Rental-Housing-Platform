APP_NAME="Rental Housing Matching System"
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://rental:rental@localhost:5432/rental_housing
ALEMBIC_DATABASE_URL=postgresql+psycopg://rental:rental@localhost:5432/rental_housing
REDIS_URL=redis://localhost:6379/0

AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_DB=rental_housing
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]
MAX_IMAGES_PER_PROPERTY=10
