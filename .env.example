APP_NAME="Rental Housing Matching System"
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://rental:rental@localhost:5432/rental_housing
ALEMBIC_DATABASE_URL=postgresql+psycopg://rental:rental@localhost:5432/rental_housing
REDIS_URL=redis://localhost:6379/0

AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins (comma-separated, or ["*"] for dev)
CORS_ORIGINS=["*"]

POSTGRES_DB=rental_housing
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental

# Redis (no password in dev)
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# 高德地图（中国大陆主引擎）
AMAP_WEB_KEY=your-amap-web-key
AMAP_JS_KEY=your-amap-js-key

# Google Maps（海外主引擎）
GM_API_KEY=your-google-maps-api-key

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]
MAX_IMAGES_PER_PROPERTY=10

# WeChat Mini Program
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Payments（默认仅测试模式；禁止填写个人静态收款码）
PAYMENTS_LIVE_ENABLED=false
WECHAT_PAY_MERCHANT_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_PATH=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
CARD_PROVIDER=
CARD_SECRET_KEY=
CARD_PUBLISHABLE_KEY=
CARD_WEBHOOK_SECRET=
CARD_SUCCESS_URL=
CARD_CANCEL_URL=
CONTRACT_EXPIRING_SOON_DAYS=30
VITE_API_PROXY_TARGET=http://localhost:8001
