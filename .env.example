APP_NAME="Rental Housing Matching System"
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://rental:rental@localhost:5432/rental_housing
ALEMBIC_DATABASE_URL=postgresql+psycopg://rental:rental@localhost:5432/rental_housing
REDIS_URL=redis://localhost:6379/0

AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins (comma-separated, or ["*"] for dev)
CORS_ORIGINS=["*"]

POSTGRES_DB=rental_housing
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental

# Redis (no password in dev)
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# 高德地图（中国大陆主引擎）
AMAP_WEB_KEY=your-amap-web-key
AMAP_JS_KEY=your-amap-js-key

# Google Maps（海外主引擎）
GM_API_KEY=your-google-maps-api-key

# 通勤结果缓存与地图 API 并发保护
COMMUTE_CACHE_ENABLED=true
COMMUTE_CACHE_TTL_SECONDS=21600
COMMUTE_FALLBACK_CACHE_TTL_SECONDS=604800
COMMUTE_API_MAX_CONCURRENCY=8
COMMUTE_API_QUEUE_TIMEOUT_SECONDS=10.0

# 地图 POI 缓存刷新
POI_MAP_CACHE_TTL_HOURS=168
POI_REFRESH_INTERVAL_SECONDS=21600
POI_REFRESH_BATCH_SIZE=200
POI_REFRESH_LOCK_SECONDS=600

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]
MAX_IMAGES_PER_PROPERTY=10

# WeChat Mini Program
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
