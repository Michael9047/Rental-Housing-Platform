APP_NAME="Rental Housing Matching System"
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://rental:rental@localhost:5432/rental_housing
ALEMBIC_DATABASE_URL=postgresql+psycopg://rental:rental@localhost:5432/rental_housing
REDIS_URL=redis://localhost:6379/0

AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins (comma-separated, or ["*"] for dev)
CORS_ORIGINS=["*"]

POSTGRES_DB=rental_housing
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental

# Redis (no password in dev)
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]
MAX_IMAGES_PER_PROPERTY=10

# WeChat Mini Program
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
